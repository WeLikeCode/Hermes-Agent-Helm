+    def _complete_deferred_registration(self) -> None:
+        """After a deferred initial connect finally succeeds, do what
+        _discover_and_register_server would have done at boot: store the server
+        and register its tools. Synchronous (runs atomically on the MCP loop).
+        No-op unless a deferred initial registration is pending."""
+        if not self._initial_registration_deferred:
+            return
+        self._initial_registration_deferred = False
+        self._error = None
+        with _lock:
+            _server_connecting.discard(self.name)
+            _server_connect_errors.pop(self.name, None)
+            _servers[self.name] = self
+        self._registered_tool_names = _register_server_tools(
+            self.name, self, self._config
+        )
+        logger.info(
+            "MCP server '%s': connected on background retry — registered "
+            "%d tool(s) that were deferred at boot: %s",
+            self.name, len(self._registered_tool_names),
