+# ---------------------------------------------------------------------------
+# Fix 5: bounded startup concurrency for initial MCP discovery
+# ---------------------------------------------------------------------------
+
+class TestDiscoverAllConcurrencyBound:
+    """_discover_all caps concurrent initial connects via a semaphore."""
+
+    def test_discover_all_bounds_startup_concurrency(self):
+        """No more than _MAX_CONCURRENT_INITIAL_CONNECTS run concurrently."""
+        from tools.mcp_tool import (
+            register_mcp_servers,
+            _servers,
+            _server_connecting,
+            _server_connect_errors,
+            _lock,
+            _MAX_CONCURRENT_INITIAL_CONNECTS,
+        )
+
+        n_servers = _MAX_CONCURRENT_INITIAL_CONNECTS * 2
+        server_names = [f"concur-test-{i}" for i in range(n_servers)]
+        fake_config = {name: {"command": "test", "args": []} for name in server_names}
+
+        current = 0
+        max_seen = 0
+
+        async def fake_discover_and_register(name, cfg):
+            nonlocal current, max_seen
+            current += 1
+            max_seen = max(max_seen, current)
+            try:
+                # Yield long enough for other guarded coroutines to pile up
+                # against the semaphore if it weren't bounding them.
+                await asyncio.sleep(0.05)
+            finally:
+                current -= 1
+            return []
+
+        try:
+            with patch(
+                "tools.mcp_tool._discover_and_register_server",
+                side_effect=fake_discover_and_register,
+            ), patch("tools.mcp_tool._MCP_AVAILABLE", True):
+                register_mcp_servers(fake_config)
+        finally:
+            with _lock:
+                for name in server_names:
+                    _servers.pop(name, None)
+                    _server_connecting.discard(name)
+                    _server_connect_errors.pop(name, None)
+
+        assert max_seen <= _MAX_CONCURRENT_INITIAL_CONNECTS, (
+            f"observed {max_seen} concurrent connects, "
+            f"expected <= {_MAX_CONCURRENT_INITIAL_CONNECTS}"
+        )
+        # With 2x the cap and a shared artificial delay, the bound should
+        # actually be reached (not just trivially satisfied by under-load).
+        assert max_seen == _MAX_CONCURRENT_INITIAL_CONNECTS
